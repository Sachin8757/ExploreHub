<% layout('./layout/boilerplate.ejs') -%>
<link rel="stylesheet" href="/stylesheets/index.css">

<div class="container">

<% lis.forEach(function(listing){ %>

<a href="/listing/details/<%= listing._id %>" class="cardLink">

    <div class="card">

        <div class="imageBox">
            <img src="<%= listing.image %>" alt="listing">
        </div>

        <div class="cardContent">

            <div class="titleRow">
                <h3><%= listing.title %></h3>
                <span>⭐ <%= listing.reviews.length > 0
                    ? (listing.reviews.reduce((acc, r) => acc + r.rating, 0) / listing.reviews.length).toFixed(1)
                    : "No ratings yet" %>
                </span>
            </div>

            <p class="location">
                <%= listing.location %>,
            </p>

            <p class="country">
                <%= listing.country %>
            </p>

        </div>

    </div>

</a>

<% }) %>

</div>