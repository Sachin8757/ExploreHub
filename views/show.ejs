<% layout('./layout/boilerplate.ejs') -%>
<link rel="stylesheet" href="/stylesheets/show.css">

<div class="main">

  <!-- ================= LISTING ================= -->
  <div class="box">
        <div class="titleRow">
        <h2><%= listing.title %></h2>

        <span class="rating">
            ⭐ <%= listing.reviews.length > 0
            ? (listing.reviews.reduce((acc, r) => acc + r.rating, 0) / listing.reviews.length).toFixed(1)
            : "No ratings yet" %>
        </span>
        </div>

    <div class="imagebox">
      <img src="<%= listing.image %>" alt="Pic Not load">
    </div>

    <div class="details">
      <span><%= listing.User.name %></span>
      <span><%= listing.state %></span>
      <span><%= listing.country %></span>
      <button class="viewbutton" onclick="openMap('<%= listing.location %>')"><i class="fa-solid fa-map-location-dot"></i> Map</button>
      <%if(CURRUSER.id==listing.User._id){%>
       <a href="/delete/<%= listing._id %>" class="viewbu">Delete</a>
      <%}%>
    </div>
  </div>

  <!-- ================= ADD REVIEW ================= -->
  <% if(CURRUSER){ %>
  <div class="commentBox">
    <h3>Add Review</h3>

    <form action="/listing/<%= listing._id %>/review" method="POST" class="reviewForm">

      <div class="starRating">
        <input type="radio" name="rating" value="5" id="star5"><label for="star5">★</label>
        <input type="radio" name="rating" value="4" id="star4"><label for="star4">★</label>
        <input type="radio" name="rating" value="3" id="star3"><label for="star3">★</label>
        <input type="radio" name="rating" value="2" id="star2"><label for="star2">★</label>
        <input type="radio" name="rating" value="1" id="star1"><label for="star1">★</label required>
      </div>

      <textarea name="comment" placeholder="Write your review..." required></textarea>
      <button type="submit">Submit Review</button>
    </form>
  </div>
  <% } %>

  <!-- ================= REVIEWS ================= -->
  <div class="rel">
    <div class="reviewHeader">
      <h3>Reviews</h3>
      <h3>
        ⭐ <%= listing.reviews.length > 0
          ? (listing.reviews.reduce((acc, r) => acc + r.rating, 0) / listing.reviews.length).toFixed(1)
          : "No ratings yet" %>
      </h3>
    </div>

    <div class="reviews">
      <% listing.reviews.forEach(r => { %>
        <div class="reviewCard">

          <div class="username">
            <span>👤 <%= r.user.name %></span>
            <span class="time"><%= timeAgo(r.createdAt) %></span>
          </div>

          <div class="stars">
            <% for(let i=1;i<=5;i++){ %>
              <% if(i <= r.rating){ %>
                <span class="filled">★</span>
              <% } else { %>
                <span>☆</span>
              <% } %>
            <% } %>
          </div>

          <p class="commentText"><%= r.comment %></p>

          <% if(r.user._id.toString() === CURRUSER.id){ %>
            <div class="reviewActions">
              <form action="/listing/<%= listing._id %>/review/<%= r._id %>/delete" method="POST">
                <button class="deleteBtn">🗑 Delete</button>
              </form>
            </div>
          <% } %>

        </div>
      <% }) %>
    </div>
  </div>

</div>

<script>
function openMap(location) {
  const url = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(location)}`;
  window.open(url, "_blank");
}
</script>