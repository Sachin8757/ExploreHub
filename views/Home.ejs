<script>
/* HERO (UPDATED + CLICKABLE) */
const hero = document.getElementById('hero');
const listingsData = <%- JSON.stringify(listings) %>;

let heroIndex = 0;

function changeHeroBg() {
  if (listingsData.length === 0) return;

  const item = listingsData[heroIndex];

  hero.style.backgroundImage = `url(${item.image})`;

  document.getElementById("hero-title").innerText = item.title;
  document.getElementById("hero-place").innerText = item.location || "Amazing Place";

  heroIndex = (heroIndex + 1) % listingsData.length;
}

changeHeroBg();
setInterval(changeHeroBg, 3000);

/* HERO CLICK */
hero.addEventListener("click", () => {
  if (listingsData.length === 0) return;

  const currentItem = listingsData[(heroIndex - 1 + listingsData.length) % listingsData.length];
  window.location.href = `/listing/details/${currentItem._id}`;
});


/* SLIDER (UPDATED CLICKABLE) */
let index = 0;
const slides = document.getElementById('slides');
const totalSlides = slides.children.length;
const dotsContainer = document.getElementById('dots');

/* 👉 CLICK EACH SLIDE */
Array.from(slides.children).forEach(slide => {
  slide.style.cursor = "pointer"; // pointer
  slide.addEventListener("click", () => {
    const id = slide.getAttribute("data-id");
    if (id) {
      window.location.href = `/listing/${id}`;
    }
  });
});

for (let i = 0; i < totalSlides; i++) {
  let dot = document.createElement('span');
  dot.classList.add('dot');
  dot.onclick = () => showSlide(i);
  dotsContainer.appendChild(dot);
}

function updateDots() {
  document.querySelectorAll('.dot').forEach(d => d.classList.remove('active'));
  if (dotsContainer.children[index]) dotsContainer.children[index].classList.add('active');
}

function showSlide(i) {
  index = i;
  slides.style.transform = `translateX(-${index * 100}%)`;
  updateDots();
}

function moveSlide(step) {
  index = (index + step + totalSlides) % totalSlides;
  showSlide(index);
}

setInterval(() => moveSlide(1), 3000);
updateDots();
</script>

</body>