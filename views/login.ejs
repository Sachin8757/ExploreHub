<% layout('./layout/boilerplate.ejs') -%>
<link rel="stylesheet" href="../stylesheets/login.css">
<div class="main">
    <div class="box">
        <h2 class="Header">ExploreHub</h2>
        <h3 class="title">Login!</h3>
        <form action="/listing/login" method="post">
            <input type="text" name="phone" class="input" placeholder="Phone" required>
            <input type="password" name="password" class="input" required placeholder="password">
            <button>Login</button>
        </form>
    </div>
</div>